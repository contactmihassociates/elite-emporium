# Allow product images in the images/ folder
!images/
!images/**
!images/**/*.jpg
!images/**/*.jpeg

# APK build artifacts — committed when GitHub Actions builds them
!release/
!release/*.apk
!release/*.aab
!release/README.md

# Local Bubblewrap build leftovers (don't commit these — they're
# regenerated by `bubblewrap build` and add MB to the repo).
app-build/app/
app-build/.gradle/
app-build/build/
app-build/app-release-signed.apk
app-build/app-release-signed.apk.idsig
app-build/app-release-bundle.aab
app-build/app-release-unsigned.apk
app-build/store_icon.png
app-build/twa-manifest.json.generated
app-build/twa-manifest.json.from-us
app-build/android.keystore
*.keystore
keystore.b64.txt
.bubblewrap/

# Editor & OS metadata
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Node deps (none committed; if anyone runs npm install locally)
node_modules/
